output Query {
    hero(Episode?): Character
    human(String): Human
    droid(Id): Droid
    characters(Id[]?): Character[]
}

enum Episode {
    NewHope
    Empire
    Jedi
}

domain Id { Number > 1000 }

output Role {
    id: Id
    name: String
    appearsIn: Episode[]
}

output Associate {
    :   Role
    friends: Role[]
}

output Human {
    :  Associate
    homePlanet: String
}

output Droid {
    :  Associate
    primaryFunction: String
}

output Character {
    | Human
    | Droid
}
